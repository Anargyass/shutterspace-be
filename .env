# ============================================================
# Shutterspace Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=8080

# Database
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=disable
DB_DSN=postgres://postgres:Zevagion123@localhost:5432/shutterspace?sslmode=disable

# JWT — WAJIB diisi, jangan di-commit nilai aslinya!
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=b2f4c9a8d7e6f5g4h3i2j1k0l9m8n7o6p5q4r3s2t1u0v9w8x7y6z5a4b3c2d1e0

# JWT expiry in hours (default: 24)
JWT_EXPIRY_HOURS=24

# CORS — URL frontend Next.js
ALLOWED_ORIGIN=http://localhost:3000

# Gin mode: debug | release
GIN_MODE=debug
